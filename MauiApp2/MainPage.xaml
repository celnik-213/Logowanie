<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp2.MainPage">

    <ScrollView>
        <VerticalStackLayout
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="15"
            Padding="30">

            <Image 
                Source="logowanie.png"
                WidthRequest="100"
             />
            <Label 
                Text="Zaloguj się"
                FontSize="32"
                HorizontalOptions="Center"/>
            <Entry 
                Placeholder="Email" 
                Keyboard="Email"
                x:Name="Email"
                TextChanged="Zmiana"/>
            <Entry 
                Placeholder="Hasło"
                IsPassword="True" 
                x:Name="Haslo"
                TextChanged="Zmiana"/>
            <Button
                 Text="Zaloguj"
                IsVisible="False"
                x:Name="Zaloguj"
                Clicked="OnButtonClicked"
                />
            <HorizontalStackLayout>
                <Label
                HorizontalOptions="Center"
                Text="Nie masz konta? Zarejestruj się"
                TextColor="Blue"
                TextDecorations="Underline"    
                Margin="0,10,0,0" />
            </HorizontalStackLayout>


        </VerticalStackLayout>


    </ScrollView>

</ContentPage>
